# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sleek

# WhatsApp — your real business number (country code, no + or spaces)
# Example Nigeria: 2348012345678
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# Meta WhatsApp Cloud API (from developers.facebook.com)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=sleek_verify_token

# Payments - Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=

# Payments - Paystack
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Payments - Cryptomus
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# Payments - Opay
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_API_URL=https://api.opaycheckout.com/api/v1

# Local SQLite (use Postgres on Vercel — see README)
DATABASE_URL="file:./dev.db"
